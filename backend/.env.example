# Copia este archivo como .env y completá los valores reales

# Conexión a PostgreSQL
# Ejemplo local: postgresql://postgres:tu_password@localhost:5432/techdrops_db
DATABASE_URL="postgresql://usuario:password@localhost:5432/nombre_db"

# Puerto del servidor
PORT=3001

# Número de WhatsApp del administrador (con código de país, sin + ni espacios)
# Ejemplo Bolivia: 59170000000
WSP_ADMIN_NUMBER="591XXXXXXXXX"