# Copia este archivo como .env y completá los valores reales

# URL base de la API del backend
# En desarrollo esto no hace falta (Vite lo proxea automáticamente)
# En producción: https://tu-dominio.com/api
VITE_API_URL=

# Número de WhatsApp del administrador (con código de país, sin + ni espacios)
# Ejemplo Bolivia: 59170000000
VITE_WSP_ADMIN=591XXXXXXXXX